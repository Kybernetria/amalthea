---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../../site-config.json';
---

<BaseLayout title="About">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">

    <!-- Header -->
    <header class="mb-16">
      <p class="typewriter text-xs text-driftwood uppercase tracking-[0.2em] mb-3">Om oss</p>
      <h1 class="font-display font-black text-espresso leading-tight mb-6" style="font-size: clamp(2.5rem, 5vw, 4rem);">
        Amalthea Bokkafé
      </h1>
      <p class="font-body italic text-driftwood text-lg mb-4">
        Malmö radical bookstore // Radikalt bokkafé i Malmö
      </p>
      <p class="typewriter text-xs text-rust uppercase tracking-wider mb-6">
        {siteConfig.description}
      </p>
      <div class="w-24 h-1 bg-rust"></div>
    </header>

    <!-- Our Story -->
    <section class="prose-dropcap mb-20">
      <div class="font-body text-driftwood leading-relaxed space-y-6 text-base">
        <p>
          Amalthea Bokkafé is a nonprofit radical bookstore and community café in Malmö, Sweden. We carry books, zines, and literature on radical politics, labor history, feminism, anti-racism, ecology, and everything in between.
        </p>
        <p>
          We're a gathering place — for reading groups, film screenings, workshops, and conversations. On Thursdays we serve soup. On weekends we pour coffee. Every day we try to build something that matters.
        </p>
        <p>
          Named after the ship <em>Amalthea</em>, whose history is woven into the story of workers' struggle in Sweden, this space carries that spirit forward: solidarity, mutual aid, and a belief that another world is not only possible but necessary.
        </p>
      </div>
    </section>

    <!-- The Space -->
    <section class="mb-20">
      <h2 class="font-display font-black text-espresso text-2xl md:text-3xl mb-8">Rummet</h2>
      <div class="font-body text-driftwood leading-relaxed space-y-4 text-base">
        <p>
          You'll find us at <strong class="text-espresso">{siteConfig.address}</strong>. The shelves hold a curated collection of radical theory, poetry, fiction, children's books, and a rotating selection of zines from local makers.
        </p>
        <p>
          The space is open for community use — reading groups, workshops, film screenings, meetings. If you have an idea for an event, get in touch.
        </p>
      </div>
    </section>

    <!-- Support -->
    <section class="bg-charcoal text-cream organic-radius p-8 md:p-12 mb-20">
      <h2 class="font-display font-black text-cream text-2xl md:text-3xl mb-6">Stötta Amalthea</h2>
      <div class="font-body text-cream/70 leading-relaxed space-y-4 text-base">
        <p>
          Amalthea is a nonprofit. We keep the doors open through book sales, event donations, and the generosity of our community. Every contribution matters.
        </p>
        <div class="bg-cream/5 border border-cream/15 rounded-sm p-6 mt-6">
          <p class="typewriter text-lg text-mustard mb-2">🚩 Swish till {siteConfig.swish}</p>
          <p class="typewriter text-sm text-cream/50">Varje krona hjälper oss hålla dörrarna öppna.</p>
        </div>
      </div>
    </section>

    <!-- Get Involved -->
    <section class="bg-bone organic-radius-alt paper-inset p-8 md:p-12">
      <h2 class="font-display font-black text-espresso text-2xl md:text-3xl mb-6">Engagera dig</h2>
      <div class="font-body text-driftwood leading-relaxed space-y-4 text-base">
        <p>
          There are many ways to be part of the project:
        </p>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong class="text-espresso">Volontär</strong> — help with events, shelving, the café, or the newsletter</li>
          <li><strong class="text-espresso">Donera</strong> — Swish till {siteConfig.swish}</li>
          <li><strong class="text-espresso">Föreslå event</strong> — the space is open for community use</li>
          <li><strong class="text-espresso">Sprid ordet</strong> — tell your friends, neighbors, coworkers</li>
        </ul>
        <p>
          Drop by the shop or email us at <a href={`mailto:${siteConfig.email}`} class="text-rust underline underline-offset-2">{siteConfig.email}</a>.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>
