---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import UpcomingEvents from '../components/UpcomingEvents.astro';
import OpeningTimes from '../components/OpeningTimes.astro';
import BlogRoll from '../components/BlogRoll.astro';
---

<BaseLayout>
  <Hero />
  <UpcomingEvents />
  <OpeningTimes />
  <BlogRoll />
</BaseLayout>

<script>
  // GSAP scroll reveals — sparingly
  async function initAnimations() {
    const { gsap } = await import('gsap');
    const { ScrollTrigger } = await import('gsap/ScrollTrigger');
    gsap.registerPlugin(ScrollTrigger);

    // Fade-in sections
    const sections = document.querySelectorAll('section');
    sections.forEach((section) => {
      gsap.from(section, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 85%',
          once: true,
        },
      });
    });

    // Stagger event cards
    const cards = document.querySelectorAll('.card-lift');
    if (cards.length) {
      gsap.from(cards, {
        opacity: 0,
        y: 20,
        stagger: 0.1,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: cards[0],
          start: 'top 85%',
          once: true,
        },
      });
    }
  }

  initAnimations();
</script>
