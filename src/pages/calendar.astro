---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calendar from '../components/Calendar.astro';
---

<BaseLayout title="Calendar">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <!-- Header -->
    <header class="mb-12">
      <p class="typewriter text-xs text-driftwood uppercase tracking-[0.2em] mb-3">Schedule</p>
      <h1 class="font-display font-black text-espresso text-3xl md:text-4xl mb-4">
        Calendar
      </h1>
      <div class="w-24 h-1 bg-rust"></div>
    </header>

    <Calendar />
  </div>
</BaseLayout>
