---
import siteConfig from '../../site-config.json';

const base = import.meta.env.BASE_URL;
const today = new Date().toLocaleDateString('en-US', { weekday: 'long' });
const todayHours = siteConfig.hours.find((h: any) => h.day === today);
const todayNote = todayHours?.note ? ` · ${todayHours.note}` : '';
const todayStatus = todayHours?.status === 'open' ? `Öppet · ${todayHours.hours}${todayNote}` : 'Stängt idag';

const navLinks = [
  { label: 'Events', href: `${base}events/` },
  { label: 'Writing', href: `${base}writing/` },
  { label: 'Calendar', href: `${base}calendar/` },
  { label: 'About', href: `${base}about/` },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-cream/90 border-b border-driftwood/20" id="main-nav">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16 md:h-18">
    <!-- Logo -->
    <a href={base} class="flex flex-col leading-tight">
      <span class="font-display font-black text-espresso text-lg md:text-xl tracking-tight">{siteConfig.name}</span>
      <span class="typewriter text-[0.55rem] text-driftwood tracking-wider hidden sm:block">{siteConfig.tagline}</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="link-slide font-heading font-semibold uppercase text-sm tracking-wider text-espresso hover:text-rust transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Hours pill (desktop) -->
    <div class="hidden lg:block">
      <button id="hours-toggle" class="typewriter text-xs text-espresso bg-bone border border-driftwood/30 px-3 py-1.5 rounded-sm hover:border-rust/50 transition-colors cursor-pointer">
        {todayStatus}
      </button>
      <!-- Hours popover -->
      <div id="hours-popover" class="absolute right-6 top-full mt-2 bg-parchment border border-driftwood/30 p-4 rounded-sm shadow-lg opacity-0 invisible transition-all duration-200 w-64">
        <h4 class="font-heading font-semibold uppercase text-xs tracking-wider text-espresso mb-3">Öppettider</h4>
        <div class="space-y-1.5">
          {siteConfig.hours.map((h: any) => (
            <div class="flex justify-between typewriter text-xs">
              <span class="text-driftwood">{h.day}</span>
              <span class={h.status === 'open' ? 'text-espresso' : 'text-driftwood/40'}>
                {h.status === 'open' ? `${h.hours}${h.note ? ` ${h.note}` : ''}` : 'Stängt'}
              </span>
            </div>
          ))}
        </div>
        <div class="mt-3 pt-3 border-t border-driftwood/15 typewriter text-[0.6rem] text-driftwood/60">
          {siteConfig.address}
        </div>
      </div>
    </div>

    <!-- Hamburger (mobile) -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5" aria-label="Open menu">
      <span class="hamburger-line w-6 h-0.5 bg-espresso transition-all duration-300"></span>
      <span class="hamburger-line w-6 h-0.5 bg-espresso transition-all duration-300"></span>
      <span class="hamburger-line w-4 h-0.5 bg-espresso transition-all duration-300 self-end"></span>
    </button>
  </div>
</nav>

<!-- Mobile overlay -->
<div id="mobile-overlay" class="nav-overlay fixed inset-0 z-40 bg-cream/98 backdrop-blur-sm flex flex-col items-center justify-center">
  <button id="mobile-close-btn" class="absolute top-5 right-6 w-10 h-10 flex items-center justify-center" aria-label="Close menu">
    <span class="font-display text-2xl text-espresso">✕</span>
  </button>
  <div class="flex flex-col items-center gap-8">
    {navLinks.map(link => (
      <a href={link.href} class="font-display font-black text-3xl text-espresso hover:text-rust transition-colors">
        {link.label}
      </a>
    ))}
    <div class="mt-4 typewriter text-sm text-driftwood text-center space-y-2">
      <p>{todayStatus}</p>
      <p class="text-xs">{siteConfig.address}</p>
      <p class="text-xs text-mustard">🚩 Swish: {siteConfig.swish}</p>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-16 md:h-18"></div>

<script>
  // Hours popover
  const toggle = document.getElementById('hours-toggle');
  const popover = document.getElementById('hours-popover');
  if (toggle && popover) {
    toggle.addEventListener('click', () => {
      const isOpen = !popover.classList.contains('invisible');
      if (isOpen) {
        popover.classList.add('invisible', 'opacity-0');
      } else {
        popover.classList.remove('invisible', 'opacity-0');
      }
    });
    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target as Node) && !popover.contains(e.target as Node)) {
        popover.classList.add('invisible', 'opacity-0');
      }
    });
  }

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const overlay = document.getElementById('mobile-overlay');
  if (menuBtn && closeBtn && overlay) {
    menuBtn.addEventListener('click', () => {
      if (overlay.classList.contains('active')) {
        overlay.classList.remove('active');
      } else {
        overlay.classList.add('active');
      }
    });
    closeBtn.addEventListener('click', () => overlay.classList.remove('active'));
    overlay.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => overlay.classList.remove('active'));
    });
  }
</script>
