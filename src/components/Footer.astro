---
import siteConfig from '../../site-config.json';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream relative z-10 w-full">
  <div class="accent-stripe"></div>

  <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">

      <!-- Contact -->
      <div class="text-center md:text-left">
        <h4 class="font-heading font-semibold uppercase tracking-wider text-sm text-cream/40 mb-3">
          <span class="lang-en">Contact</span>
          <span class="lang-sv">Kontakt</span>
        </h4>
        <a href={`mailto:${siteConfig.email}`} class="block font-heading text-xl md:text-2xl text-cream/80 hover:text-mustard transition-colors mb-4 tracking-wide">
          {siteConfig.email}
        </a>
        <div class="flex justify-center md:justify-start gap-4">
          {siteConfig.socials.instagram && (
            <a href={siteConfig.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-cream/40 hover:text-mustard transition-colors" aria-label="Instagram">
              <svg class="w-6 h-6 md:w-7 md:h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="5"></circle><circle cx="17.5" cy="6.5" r="1.5"></circle></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Swish -->
      <div class="bg-cream/5 border border-cream/10 rounded-lg p-6 md:p-8 text-center">
        <p class="font-heading text-sm md:text-base text-cream/50 mb-2 tracking-wider">
          <span class="lang-en">🚩 Support Amalthea</span>
          <span class="lang-sv">🚩 Stötta Amalthea</span>
        </p>
        <p class="font-heading text-2xl md:text-3xl text-mustard tracking-wide">Swish {siteConfig.swish}</p>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="accent-stripe"></div>
  <div class="">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="font-heading text-sm md:text-base text-cream/25 tracking-wide">
        © {currentYear} {siteConfig.name} · CC BY-SA 4.0
      </p>
      <div class="flex items-center gap-3">
        <img src={`${base}flower.png`} alt="" class="w-8 h-8 opacity-30 hover:opacity-60 transition-opacity duration-300" aria-hidden="true" />
        <span class="font-heading text-sm md:text-base text-cream/25 uppercase tracking-widest">
          <span class="lang-en">Solidarity every day</span>
          <span class="lang-sv">Solidaritet varje dag</span>
        </span>
      </div>
    </div>
  </div>
</footer>
