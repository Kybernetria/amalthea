---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allEvents = (await getCollection('events', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const eventTypeColors: Record<string, string> = {
  reading: 'bg-rust',
  workshop: 'bg-sage',
  discussion: 'bg-mustard',
  film: 'bg-charcoal',
  meeting: 'bg-driftwood',
  other: 'bg-espresso',
};
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {allEvents.map((event) => {
    const d = new Date(event.data.date);
    const dayStr = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }).toUpperCase();
    const typeColor = eventTypeColors[event.data.eventType] || 'bg-espresso';
    return (
      <a href={`${base}events/${event.id}/`} class="block group">
        <article class="bg-parchment paper-inset organic-radius border-l-4 border-l-rust p-6 h-full flex flex-col card-lift corner-fold relative">
          {/* Date */}
          <p class="typewriter text-xs text-driftwood tracking-wider mb-2">{dayStr}</p>

          {/* Title */}
          <h3 class="font-heading font-semibold text-espresso text-lg mb-2 group-hover:text-rust transition-colors leading-snug">
            {event.data.title}
          </h3>

          {/* Time + Location */}
          <p class="typewriter text-xs text-driftwood mb-3">
            {event.data.startTime}{event.data.endTime ? ` – ${event.data.endTime}` : ''} · {event.data.location}
          </p>

          {/* Excerpt */}
          <p class="font-body text-sm text-driftwood leading-relaxed line-clamp-2 flex-1 mb-4">
            {event.data.excerpt}
          </p>

          {/* Tag */}
          <span class={`inline-block self-start text-xs font-heading uppercase tracking-wider text-parchment px-2.5 py-0.5 rounded-sm ${typeColor}`}>
            {event.data.eventType}
          </span>
        </article>
      </a>
    );
  })}
</div>
