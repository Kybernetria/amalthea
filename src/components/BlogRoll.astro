---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---

<section class="py-20 md:py-28 bg-cream relative">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-12">
    <div class="mb-12">
      <div class="inline-block">
        <h2 class="font-display font-black text-espresso text-3xl md:text-4xl mb-2">
          <span class="lang-en">From the Shelf</span>
          <span class="lang-sv">Från hyllan</span>
        </h2>
        <div class="w-full h-1 bg-rust"></div>
      </div>
    </div>
    </div>

    <!-- Posts grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => {
        const dateStr = new Date(post.data.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });
        return (
          <a href={`${base}writing/${post.id}/`} class="block group">
            <article class="bg-parchment rounded-lg p-6 h-full flex flex-col card-lift">
              {/* Hero image */}
              {post.data.heroImage && (
                <div class="mb-4 overflow-hidden rounded-lg border border-driftwood/20 bg-charcoal/5 flex items-center justify-center">
                  <img 
                    src={post.data.heroImage.startsWith('http') ? post.data.heroImage : `${base}${post.data.heroImage.startsWith('/') ? post.data.heroImage.slice(1) : post.data.heroImage}`} 
                    alt="" 
                    class="max-w-full max-h-[250px] w-auto h-auto object-contain photo-grain" 
                  />
                </div>
              )}

              {/* Date */}
              <p class="font-heading text-xs text-driftwood mb-2 tracking-wider">{dateStr}</p>

              {/* Tags */}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {post.data.tags.map((tag: string) => (
                    <span class="text-[0.65rem] font-heading uppercase tracking-wider border border-rust/40 text-rust px-1.5 py-0.5 rounded-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              {/* Title */}
              <h3 class="font-heading font-semibold text-espresso text-lg mb-3 group-hover:text-rust transition-colors leading-snug">
                {post.data.title}
              </h3>

              {/* Excerpt */}
              <p class="font-body text-sm text-driftwood leading-relaxed line-clamp-3 flex-1">
                {post.data.excerpt}
              </p>

              {/* Read link — always visible */}
              <span class="mt-4 text-rust text-sm font-heading uppercase tracking-wider group-hover:translate-x-1 transition-transform">
                <span class="lang-en">Read →</span>
                <span class="lang-sv">Läs →</span>
              </span>
            </article>
          </a>
        );
      })}
    </div>

    {/* View all link */}
    <div class="text-center mt-12">
      <a href={`${base}writing/`} class="link-slide font-heading font-semibold uppercase text-sm tracking-wider text-rust inline-flex items-center gap-2">
        <span class="lang-en">All Writing</span>
        <span class="lang-sv">Alla texter</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
