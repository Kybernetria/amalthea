---
import siteConfig from '../../site-config.json';

const base = import.meta.env.BASE_URL;
---

<section class="relative min-h-[90dvh] flex items-end overflow-hidden bg-charcoal">
  <!-- Background image with picture element -->
  <div class="absolute inset-0">
    <picture>
      <source
        srcset={`${base}Amaltheahero-960.webp`}
        media="(max-width: 768px)"
        type="image/webp"
      />
      <source
        srcset={`${base}Amaltheahero.webp`}
        type="image/webp"
      />
      <source
        srcset={`${base}Amaltheahero-960.jpg`}
        media="(max-width: 768px)"
        type="image/jpeg"
      />
      <img
        src={`${base}Amaltheahero.jpg`}
        alt="Amalthea Bokkafé interior"
        class="w-full h-full object-cover opacity-45"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/60 to-charcoal/20"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 md:pb-24 pt-32 w-full">
    <div class="max-w-xl">
      <!-- Headline -->
      <h1 class="hero-fade font-display font-black text-parchment leading-[1.05] mb-5" style="font-size: clamp(2.8rem, 6vw, 4.5rem);">
        Amalthea<br/>Bokkafé
      </h1>

      <!-- One line — no-wrap to prevent layout shift on lang toggle -->
      <p class="hero-fade hero-fade-delay-1 font-body italic text-cream/75 text-lg md:text-xl leading-relaxed mb-10 whitespace-nowrap">
        <span class="lang-en">Radical bookstore and community café in Malmö.</span>
        <span class="lang-sv">Radikalt bokkafé i Malmö.</span>
      </p>

      <!-- CTA -->
      <div class="hero-fade hero-fade-delay-2 flex flex-wrap gap-4">
        <a href={`${base}events/`} class="btn-fill font-heading font-semibold uppercase text-sm tracking-wider border-2 border-rust text-parchment bg-rust/90 px-6 py-3 inline-block transition-colors hover:bg-rust rounded-sm">
          <span class="lang-en">Upcoming Events</span>
          <span class="lang-sv">Kommande event</span>
        </a>
        <a href={`${base}about/`} class="font-heading font-semibold uppercase text-sm tracking-wider text-cream/70 px-6 py-3 inline-block hover:text-mustard transition-colors">
          <span class="lang-en">About Us →</span>
          <span class="lang-sv">Om oss →</span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 accent-stripe"></div>
</section>
