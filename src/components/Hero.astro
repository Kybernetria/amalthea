---
import siteConfig from '../../site-config.json';

const base = import.meta.env.BASE_URL;
const today = new Date().toLocaleDateString('en-US', { weekday: 'long' });
const todayHours = siteConfig.hours.find((h: any) => h.day === today);

const todayNote = todayHours?.note ? ` · ${todayHours.note}` : '';
const todayStatus = todayHours?.status === 'open'
  ? `Öppet idag · ${todayHours.hours}${todayNote}`
  : 'Stängt idag';
---

<section class="relative min-h-[90dvh] flex items-end overflow-hidden bg-charcoal">
  <!-- Background image with warm overlay -->
  <div class="absolute inset-0">
    <img
      src={`${base}Amaltheahero.jpg`}
      alt="Amalthea Bokkafé interior"
      class="w-full h-full object-cover opacity-50"
      loading="eager"
    />
    <!-- Warm gradient overlays -->
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/70 to-charcoal/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/80 via-transparent to-transparent"></div>
  </div>

  <!-- Text content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 md:pb-24 pt-32 w-full">
    <div class="max-w-2xl">
      <!-- Label -->
      <p class="typewriter text-xs text-mustard uppercase tracking-[0.25em] mb-4">
        Ideell förening · Malmö
      </p>

      <!-- Headline -->
      <h1 class="font-display font-black text-parchment leading-[1.05] mb-6" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Amalthea<br/>Bokkafé
      </h1>

      <!-- Subhead — bilingual -->
      <p class="font-body italic text-cream/80 text-lg md:text-xl leading-relaxed mb-4 max-w-lg">
        Malmö radical bookstore // Radikalt bokkafé i Malmö
      </p>
      <p class="font-body text-cream/60 text-base leading-relaxed mb-10 max-w-lg">
        Books, soup, events, and community organizing in Kristianstad&shy;sgatan.
      </p>

      <!-- CTA row -->
      <div class="flex flex-wrap gap-4 mb-10">
        <a href={`${base}events/`} class="btn-fill font-heading font-semibold uppercase text-sm tracking-wider border-2 border-rust text-parchment bg-rust/90 px-6 py-3 inline-block transition-colors hover:bg-rust">
          Kommande event
        </a>
        <a href={`${base}about/`} class="font-heading font-semibold uppercase text-sm tracking-wider text-cream/80 px-6 py-3 inline-block hover:text-mustard transition-colors">
          Om oss →
        </a>
      </div>

      <!-- Hours + Support row -->
      <div class="flex flex-wrap gap-4 items-center">
        <div class="typewriter text-sm text-parchment bg-charcoal/80 border border-driftwood/40 px-4 py-2 rounded-sm backdrop-blur-sm">
          {todayStatus}
        </div>
        <div class="typewriter text-sm text-mustard bg-charcoal/80 border border-mustard/30 px-4 py-2 rounded-sm backdrop-blur-sm">
          🚩 Stötta Amalthea? Swish till {siteConfig.swish}
        </div>
      </div>
    </div>
  </div>

  <!-- Warm accent stripe at bottom -->
  <div class="absolute bottom-0 left-0 right-0 accent-stripe"></div>
</section>
