---
import siteConfig from '../../site-config.json';

const base = import.meta.env.BASE_URL;
---

<section class="relative min-h-[90svh] flex items-end overflow-hidden w-full">
  <!-- Background: storefront photo -->
  <div class="absolute inset-0 pointer-events-none">
    <img
      src={`${base}storefront.jpg`}
      alt="Amalthea Bokkafé storefront on Kristianstadsgatan"
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Gradient overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/70 to-charcoal/20 pointer-events-none"></div>

  <!-- Open/Closed indicator - mobile only -->
  <div class="absolute top-[72px] left-0 right-0 z-20 md:hidden">
    <div id="hero-open-status" class="text-center">
      <span class="inline-block bg-charcoal/80 text-white font-heading text-sm font-bold px-4 py-2 tracking-wider rounded-sm">
        <span class="lang-en"></span>
        <span class="lang-sv"></span>
      </span>
    </div>
  </div>

  <!-- Content: centered on mobile, left on desktop -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 md:pb-24 -mt-2 md:mt-0 md:pt-32 w-full">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between w-full gap-12">
      <div class="w-full md:w-2/3 lg:w-1/2 md:ml-0 text-center md:text-left">
      <!-- Headline -->
      <h1 class="hero-fade font-display font-black text-white leading-[1.05] mb-3 text-[clamp(3rem,10vw,4.5rem)] md:text-[clamp(3.5rem,8vw,5.25rem)] h-[clamp(6rem,20vw,10.5rem)] md:h-[clamp(7rem,16vw,11rem)] overflow-hidden drop-shadow-lg">
        Amalthea<br/>Bokkafé
      </h1>

      <!-- One line — no-wrap to prevent layout shift on lang toggle -->
      <p class="hero-fade hero-fade-delay-1 font-body italic text-white text-lg md:text-[1.3rem] leading-relaxed mb-10 md:whitespace-nowrap h-8 md:h-10 mt-[2px] drop-shadow-md">
        <span class="lang-en block">Radical bookstore and community café in Malmö.</span>
        <span class="lang-sv block">Radikalt bokkafé i Malmö.</span>
      </p>

      <!-- CTA -->
      <div class="hero-fade hero-fade-delay-2 flex flex-wrap gap-4 justify-center md:justify-start mt-2 md:mt-0 relative z-20">
        <a href={`${base}events/`} class="btn-fill font-heading font-semibold uppercase text-sm tracking-wider border-2 border-rust text-white bg-rust/90 px-6 py-3 inline-block transition-colors hover:bg-rust rounded-sm">
          <span class="lang-en">Upcoming Events</span>
          <span class="lang-sv">Kommande</span>
        </a>
        <a href={`${base}about/`} class="font-heading font-semibold uppercase text-sm tracking-wider text-white/90 px-6 py-3 inline-block hover:text-mustard transition-colors drop-shadow-md">
          <span class="lang-en">About Us →</span>
          <span class="lang-sv">Om oss →</span>
        </a>
      </div>
      </div>
      
      <!-- Right-aligned Logo Test (Desktop Only) -->
      <div class="hidden md:flex w-1/3 lg:w-1/2 justify-end hero-fade drop-shadow-[0_25px_50px_rgba(0,0,0,0.65)] pointer-events-none">
        <img src={`${base}logo.png`} alt="Logo" class="w-80 lg:w-[450px] h-auto object-contain opacity-95" />
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 accent-stripe"></div>
</section>

<script>
  function updateOpenStatus() {
    const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    const now = new Date();
    const dayName = dayNames[now.getDay()];
    
    const hours: Record<string, string | null> = { 'Monday': null, 'Tuesday': '10:00–19:00', 'Wednesday': null, 'Thursday': '18:00–20:00', 'Friday': null, 'Saturday': '12:00–16:00', 'Sunday': '12:00–16:00' };
    const isOpen = hours[dayName] !== null;
    
    const statusEl = document.getElementById('hero-open-status');
    if (statusEl) {
      const textEn = statusEl.querySelector('.lang-en');
      const textSv = statusEl.querySelector('.lang-sv');
      
      if (isOpen) {
        if (textEn) textEn.textContent = `Open · ${hours[dayName]}`;
        if (textSv) textSv.textContent = `Öppet · ${hours[dayName]}`;
      } else {
        if (textEn) textEn.textContent = 'Closed today';
        if (textSv) textSv.textContent = 'Stängt idag';
      }
    }
  }

  updateOpenStatus();
  document.addEventListener('astro:after-swap', updateOpenStatus);
</script>
