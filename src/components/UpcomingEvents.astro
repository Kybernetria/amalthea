---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allEvents = await getCollection('events', ({ data }) => !data.draft);
const now = new Date();
const upcomingEvents = allEvents
  .filter(e => new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 4);

const events = upcomingEvents.length > 0
  ? upcomingEvents
  : allEvents.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 4);

const eventTypeColors: Record<string, string> = {
  reading: 'bg-rust',
  workshop: 'bg-sage',
  discussion: 'bg-mustard',
  film: 'bg-charcoal',
  meeting: 'bg-driftwood',
  other: 'bg-espresso',
};
---

<section class="py-20 md:py-28 bg-gradient-to-b from-cream to-bone/40 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="lg:flex lg:gap-12">
      <!-- Left label -->
      <div class="lg:w-[200px] flex-shrink-0 mb-10 lg:mb-0 lg:relative">
        <div class="lg:sticky lg:top-28">
          <h2 class="font-display font-black text-espresso text-4xl md:text-5xl lg:text-6xl lg:[writing-mode:vertical-lr] lg:rotate-180 leading-none tracking-tight">
            <span class="lang-en">Upcoming</span>
            <span class="lang-sv">Kommande</span>
          </h2>
        </div>
      </div>

      <!-- Events stack -->
      <div class="flex-1 space-y-5">
        {events.map((event) => {
          const d = new Date(event.data.date);
          const dayStr = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }).toUpperCase();
          const typeColor = eventTypeColors[event.data.eventType] || 'bg-espresso';
          return (
            <a href={`${base}events/${event.id}/`} class="block group">
              <article class="bg-parchment rounded-lg border-l-4 border-l-rust p-6 md:p-8 card-lift relative overflow-hidden">
                {/* Event image */}
                {event.data.image && (
                  <div class="mb-4 -mx-6 md:-mx-8 -mt-6 md:-mt-8 bg-charcoal/5 flex items-center justify-center">
                    <img 
                      src={event.data.image.startsWith('http') ? event.data.image : `${base}${event.data.image.startsWith('/') ? event.data.image.slice(1) : event.data.image}`} 
                      alt="" 
                      class="max-w-full max-h-[300px] w-auto h-auto object-contain photo-grain" 
                    />
                  </div>
                )}
                <!-- Date -->
                <div class="flex items-center gap-2 mb-3">
                  <svg class="w-4 h-4 text-driftwood" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <span class="font-heading text-xs text-driftwood tracking-wider">{dayStr}</span>
                </div>

                <!-- Title -->
                <h3 class="font-heading font-semibold text-espresso text-lg md:text-xl mb-2 group-hover:text-rust transition-colors">
                  {event.data.title}
                </h3>

                <!-- Time + Location -->
                <p class="font-heading text-xs text-driftwood mb-3 tracking-wide">
                  {event.data.startTime}{event.data.endTime ? ` – ${event.data.endTime}` : ''} · {event.data.location}
                </p>

                <!-- Excerpt -->
                <p class="font-body text-sm text-driftwood leading-relaxed line-clamp-2 mb-4">
                  {event.data.excerpt}
                </p>

                <!-- Tag pill -->
                <span class={`inline-block text-xs font-heading uppercase tracking-wider text-parchment px-2.5 py-0.5 rounded-sm ${typeColor}`}>
                  {event.data.eventType}
                </span>
              </article>
            </a>
          );
        })}

        <!-- View all events link -->
        <div class="text-center pt-4">
          <a href={`${base}events/`} class="link-slide font-heading font-semibold uppercase text-sm tracking-wider text-rust inline-flex items-center gap-2">
            <span class="lang-en">All Events</span>
            <span class="lang-sv">Alla event</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
